{
  "id": "default",
  "name": "Default",
  "builtIn": true,
  "description": "Balanced labels, folder-aware coloring, and link styling.",
  "renderMode": "dynamic",
  "layout": "breadthfirst",
  "showNodeLabels": true,
  "showEdgeLabels": true,
  "emojiMode": true,
  "imageMode": true,
  "includeUnresolved": true,
  "includeAttachments": true,
  "propertyBasedColoring": true,
  "linkTypeStyling": true,
  "performanceMode": true,
  "neighborhoodDepth": 2,
  "centerForce": 0.3,
  "repelForce": 14,
  "linkStrength": 0.4,
  "linkDistance": 140,
  "activeFps": 30,
  "idleFps": 8,
  "idleAlphaFloor": 0.08,
  "defaultNodeStyle": {
    "fillColor": "#8a7dff",
    "borderColor": "rgba(84, 90, 112, 0.28)",
    "borderWidth": 1.25,
    "shape": "round-rectangle",
    "size": 38,
    "opacity": 1,
    "labelVisibility": true
  },
  "defaultEdgeStyle": {
    "color": "rgba(93, 105, 123, 0.48)",
    "width": 1.6,
    "opacity": 0.72,
    "dashStyle": "solid",
    "arrowShape": "none"
  },
  "nodeStyleRules": [
    {
      "id": "folder-inbox",
      "label": "Inbox / triage",
      "enabled": true,
      "match": {
        "pathIncludes": [
          "00_Inbox"
        ]
      },
      "style": {
        "fillColor": "#ff9b42",
        "emoji": "\ud83d\udce5",
        "icon": "inbox"
      }
    },
    {
      "id": "folder-daily",
      "label": "Daily",
      "enabled": true,
      "match": {
        "pathIncludes": [
          "01_Daily"
        ]
      },
      "style": {
        "fillColor": "#f2c14e",
        "emoji": "\ud83d\uddd3\ufe0f",
        "icon": "calendar"
      }
    },
    {
      "id": "folder-action",
      "label": "Action",
      "enabled": true,
      "match": {
        "pathIncludes": [
          "02_Action"
        ]
      },
      "style": {
        "fillColor": "#e9b95e",
        "emoji": "\u2705",
        "icon": "check-square"
      }
    },
    {
      "id": "folder-maps",
      "label": "Maps / hubs",
      "enabled": true,
      "match": {
        "pathIncludes": [
          "04_Maps"
        ]
      },
      "style": {
        "fillColor": "#3ccfcf",
        "shape": "hexagon",
        "emoji": "\ud83e\udded",
        "icon": "map"
      }
    },
    {
      "id": "folder-sources",
      "label": "Sources / PDFs",
      "enabled": true,
      "match": {
        "pathIncludes": [
          "05_Sources"
        ]
      },
      "style": {
        "fillColor": "#53a8ff",
        "emoji": "\ud83d\udcd8",
        "icon": "book"
      }
    },
    {
      "id": "folder-reference",
      "label": "References",
      "enabled": true,
      "match": {
        "pathIncludes": [
          "06_Reference"
        ]
      },
      "style": {
        "fillColor": "#69c17d",
        "emoji": "\ud83d\udcda",
        "icon": "stack"
      }
    },
    {
      "id": "folder-persona",
      "label": "Persona",
      "enabled": true,
      "match": {
        "pathIncludes": [
          "07_Persona"
        ]
      },
      "style": {
        "fillColor": "#d96faf",
        "emoji": "\ud83d\udc64",
        "icon": "user"
      }
    },
    {
      "id": "folder-system",
      "label": "System",
      "enabled": true,
      "match": {
        "pathIncludes": [
          "08_System"
        ]
      },
      "style": {
        "fillColor": "#a3b3c7",
        "emoji": "\u2699\ufe0f",
        "icon": "gear"
      }
    },
    {
      "id": "folder-archive",
      "label": "Archive",
      "enabled": true,
      "match": {
        "pathIncludes": [
          "90_Archive"
        ]
      },
      "style": {
        "fillColor": "#6a7282",
        "opacity": 0.76,
        "emoji": "\ud83d\uddc4\ufe0f",
        "icon": "archive"
      }
    },
    {
      "id": "folder-assets",
      "label": "Assets",
      "enabled": true,
      "match": {
        "pathIncludes": [
          "_Assets"
        ]
      },
      "style": {
        "fillColor": "#7d8aa6",
        "shape": "diamond",
        "opacity": 0.86,
        "emoji": "\ud83d\uddbc\ufe0f",
        "icon": "attachment"
      }
    },
    {
      "id": "attachment-nodes",
      "label": "Attachment nodes",
      "enabled": true,
      "match": {
        "isAttachment": true
      },
      "style": {
        "fillColor": "#8db4d8",
        "shape": "diamond",
        "size": 32,
        "emoji": "\ud83d\uddbc\ufe0f",
        "icon": "attachment"
      }
    },
    {
      "id": "unresolved-nodes",
      "label": "Unresolved nodes",
      "enabled": true,
      "match": {
        "isUnresolved": true
      },
      "style": {
        "fillColor": "#d46a5c",
        "borderColor": "#ffd0cc",
        "shape": "triangle",
        "emoji": "\u2753",
        "icon": "alert"
      }
    },
    {
      "id": "system-type",
      "label": "System note type",
      "enabled": true,
      "match": {
        "noteType": "system"
      },
      "style": {
        "emoji": "\u2699\ufe0f",
        "icon": "gear"
      }
    },
    {
      "id": "idea-type",
      "label": "Concept / idea type",
      "enabled": true,
      "match": {
        "noteType": "concept"
      },
      "style": {
        "emoji": "\ud83d\udca1",
        "icon": "idea"
      }
    },
    {
      "id": "paradox-type",
      "label": "Paradox / contrast type",
      "enabled": true,
      "match": {
        "noteNamePattern": "paradox|contrast"
      },
      "style": {
        "emoji": "\ud83c\udf00",
        "icon": "paradox"
      }
    },
    {
      "id": "people-tag",
      "label": "People tag",
      "enabled": true,
      "match": {
        "tags": [
          "person",
          "people"
        ]
      },
      "style": {
        "emoji": "\ud83d\udc64",
        "icon": "user"
      }
    }
  ],
  "edgeTypeRules": {
    "related": {
      "type": "related",
      "enabled": true,
      "color": "rgba(173,183,199,0.55)",
      "width": 1.6,
      "dashStyle": "solid"
    },
    "friend": {
      "type": "friend",
      "enabled": true,
      "color": "#7aa2f7",
      "width": 2.8,
      "dashStyle": "solid",
      "arrowShape": "triangle"
    },
    "supports": {
      "type": "supports",
      "enabled": true,
      "color": "#72d49f",
      "width": 2.5,
      "dashStyle": "solid",
      "arrowShape": "triangle"
    },
    "source": {
      "type": "source",
      "enabled": true,
      "color": "#53a8ff",
      "width": 2.2,
      "dashStyle": "dashed",
      "arrowShape": "triangle"
    },
    "example": {
      "type": "example",
      "enabled": true,
      "color": "#ffb36b",
      "width": 2.2,
      "dashStyle": "dotted",
      "arrowShape": "triangle"
    },
    "contrast": {
      "type": "contrast",
      "enabled": true,
      "color": "#ff8e6b",
      "width": 2.8,
      "dashStyle": "dashed",
      "arrowShape": "diamond"
    },
    "child": {
      "type": "child",
      "enabled": true,
      "color": "#8a7dff",
      "width": 2.4,
      "dashStyle": "solid",
      "arrowShape": "triangle"
    },
    "parent": {
      "type": "parent",
      "enabled": true,
      "color": "#8a7dff",
      "width": 2.4,
      "dashStyle": "solid",
      "arrowShape": "triangle"
    }
  },
  "manualNodeOverrides": [],
  "userPresets": [
    {
      "id": "user-mobile-dense",
      "name": "Mobile Dense Review",
      "description": "Tighter spacing and lighter chrome for quick Samsung-phone scans.",
      "renderMode": "dynamic",
      "layout": "cose",
      "showNodeLabels": true,
      "showEdgeLabels": false,
      "emojiMode": false,
      "imageMode": false,
      "includeUnresolved": false,
      "includeAttachments": false,
      "propertyBasedColoring": true,
      "linkTypeStyling": true,
      "performanceMode": true,
      "neighborhoodDepth": 1,
      "centerForce": 0.8,
      "repelForce": 9,
      "linkStrength": 1.1,
      "linkDistance": 165,
      "activeFps": 30,
      "idleFps": 8,
      "idleAlphaFloor": 0.014
    },
    {
      "id": "user-cluster-review",
      "name": "Cluster Review",
      "description": "Wider spacing for topic-cluster inspection and map cleanup.",
      "renderMode": "dynamic",
      "layout": "cose",
      "showNodeLabels": true,
      "showEdgeLabels": false,
      "emojiMode": false,
      "imageMode": false,
      "includeUnresolved": false,
      "includeAttachments": false,
      "propertyBasedColoring": true,
      "linkTypeStyling": true,
      "performanceMode": false,
      "neighborhoodDepth": 2,
      "centerForce": 0.46,
      "repelForce": 18,
      "linkStrength": 0.9,
      "linkDistance": 250,
      "activeFps": 30,
      "idleFps": 8,
      "idleAlphaFloor": 0.014
    }
  ],
  "aliases": {
    "nodeColorFields": [
      "graphColor",
      "graph-color",
      "color"
    ],
    "nodeBorderColorFields": [
      "graphBorderColor",
      "graph-border-color",
      "borderColor"
    ],
    "nodeBorderWidthFields": [
      "graphBorderWidth",
      "graph-border-width",
      "borderWidth"
    ],
    "nodeShapeFields": [
      "graphShape",
      "graph-shape",
      "shape"
    ],
    "nodeSizeFields": [
      "graphSize",
      "graph-size",
      "size"
    ],
    "nodeOpacityFields": [
      "graphOpacity",
      "graph-opacity",
      "opacity"
    ],
    "nodeEmojiFields": [
      "graphEmoji",
      "graph-emoji",
      "emoji"
    ],
    "nodeIconFields": [
      "graphIcon",
      "graph-icon",
      "icon"
    ],
    "nodeImageFields": [
      "graphImage",
      "graph-image",
      "image"
    ],
    "nodeLabelVisibilityFields": [
      "graphLabel",
      "graph-label",
      "labelVisibility"
    ],
    "noteTypeFields": [
      "kind",
      "type",
      "noteType",
      "note-type"
    ],
    "nodeConfigFields": [
      "advanced-graph",
      "advancedGraph"
    ],
    "edgeStyleFields": [
      "graphEdgeStyles",
      "graph-edge-styles",
      "outgoing"
    ]
  },
  "experimentalNativeGraphBridge": true
}
